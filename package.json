{
  "name": "mp-dev-tools",
  "version": "0.1.0",
  "private": true,
  "main": "electron/dist/main.js",
  "scripts": {
    "dev:next": "next dev",
    "build:next": "next build",
    "dev:electron": "tsc -p electron/tsconfig.json && electron .",
    "dev": "npm run build:next && npm run dev:electron",
    "build": "npm run build:next && tsc -p electron/tsconfig.json",
    "start": "npm run build && electron ."
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "electron": "41.3.0",
    "postcss": "8.5.12",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3"
  }
}
